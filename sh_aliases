# Enable color support for ls
#
#
if [ "${COLOR_SUPPORT}" = 1 ]; then
    if ls --color > /dev/null 2>&1; then
        alias l='ls --color=always'
    elif colorls > /dev/null 2>&1; then
        LSCOLORS="exfxcxdxbxgxDxBxGxCbCx"; export LSCOLORS
        alias l='colorls -G'
    else
        alias l='ls -F'
    fi
else
    alias l='ls -F'
fi

