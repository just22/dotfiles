# Find files by name
ff() {
    if [ "$1" == "-h" ]; then
        echo "usage: ff [-r] pattern"
	return
    elif [ "$1" == "-r" ]; then
        shift
    else
        local FIND_OPT="-maxdepth 1"
    fi
    find . $FIND_OPT -name "*${1}*" -ls
}

# List broken links
bl() {
    find -L ${1-.} -maxdepth 1 -type l -ls |
        awk '{printf "%s %s %s\n", $11, $12, $13}'
}

