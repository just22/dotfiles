# ----------------------------------------------------------------------
# Calendar
#
#
if cal -3 > /dev/null 2>&1; then
    # GNU version
    alias cal='cal -m3'
else
    # BSD version
    alias cal='cal -mw | sed -E "2,\$s/(^|[^0-9])($(date +%e))( |$)/\1$(tput rev)$(echo "\2")$(tput sgr0)\3/g"'
fi
alias now='date "+%a %d %b %Y %Z (WK%g%V) - %H:%M"'

# ----------------------------------------------------------------------
# Colorize grep
#
#
if echo "x" | grep --color "x" > /dev/null 2>&1; then
    alias grepc='grep --color'
    alias egrepc='egrep --color'
    alias fgrepc='fgrep --color'
    alias zgrepc='zgrep --color'
elif [ -e /usr/local/bin/ggrep ]; then
    # GNU grep certainly has color support
    alias grepc='ggrep --color'
    alias egrepc='gegrep --color'
    alias fgrepc='gfgrep --color'
    alias zgrepc='gzgrep --color'
fi

