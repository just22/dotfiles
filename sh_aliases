# ----------------------------------------------------------------------
# Safe remove
#
#
del() {
    if [ $# == 0 ]; then
	echo "usage: del source ..."
        return
    fi
    for f in $(ls $*); do
        ff=$(readlink -f $f | tr "/" "%")
	mv -f $f ~/.#trash#/"$ff"
	touch ~/.#trash#/"$ff"
    done
}

